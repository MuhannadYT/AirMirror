<Window x:Class="AirMirror.PlaybackWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        Title="AirPlay Video"
        Width="1200"
        Height="720"
        MinWidth="640"
        MinHeight="360"
        WindowStartupLocation="CenterScreen"
        Background="Black"
        Closing="OnClosing"
        PreviewKeyDown="OnPreviewKeyDown"
        MouseMove="OnRootMouseMove"
        MouseLeave="OnRootMouseLeave"
        LocationChanged="OnWindowGeometryChanged"
        StateChanged="OnWindowStateChanged"
        SizeChanged="OnWindowSizeChanged"
        Deactivated="OnWindowDeactivated"
        Activated="OnWindowActivated">
  <Window.Resources>
    <SolidColorBrush x:Key="ChromeText" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ChromeMuted" Color="#D8D8D8"/>
    <SolidColorBrush x:Key="YouTubeRed" Color="#FF0033"/>

    <Style x:Key="PlayerButton" TargetType="Button">
      <Setter Property="Focusable" Value="False"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground" Value="{StaticResource ChromeText}"/>
      <Setter Property="FontFamily" Value="Segoe UI"/>
      <Setter Property="FontSize" Value="20"/>
      <Setter Property="Width" Value="40"/>
      <Setter Property="Height" Value="40"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Opacity" Value="1"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}" CornerRadius="20">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                TextElement.Foreground="{TemplateBinding Foreground}"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#26FFFFFF"/>
                <Setter Property="Opacity" Value="1"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.35"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="SmallPlayerButton" TargetType="Button" BasedOn="{StaticResource PlayerButton}">
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="Width" Value="40"/>
    </Style>

    <Style x:Key="ProgressSlider" TargetType="Slider">
      <Setter Property="Focusable" Value="False"/>
      <Setter Property="Foreground" Value="{StaticResource YouTubeRed}"/>
      <Setter Property="Background" Value="#66FFFFFF"/>
      <Setter Property="Height" Value="14"/>
      <Setter Property="IsMoveToPointEnabled" Value="True"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Slider">
            <Grid>
              <Border Height="3" Background="{TemplateBinding Background}" VerticalAlignment="Center" CornerRadius="1.5"/>
              <Track x:Name="PART_Track">
                <Track.DecreaseRepeatButton>
                  <RepeatButton Command="Slider.DecreaseLarge">
                    <RepeatButton.Template>
                      <ControlTemplate TargetType="RepeatButton">
                        <Border Height="3" Background="{TemplateBinding Foreground}" CornerRadius="1.5"/>
                      </ControlTemplate>
                    </RepeatButton.Template>
                    <RepeatButton.Foreground>
                      <Binding RelativeSource="{RelativeSource AncestorType=Slider}" Path="Foreground"/>
                    </RepeatButton.Foreground>
                  </RepeatButton>
                </Track.DecreaseRepeatButton>
                <Track.IncreaseRepeatButton>
                  <RepeatButton Command="Slider.IncreaseLarge">
                    <RepeatButton.Template>
                      <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent"/>
                      </ControlTemplate>
                    </RepeatButton.Template>
                  </RepeatButton>
                </Track.IncreaseRepeatButton>
                <Track.Thumb>
                  <Thumb>
                    <Thumb.Template>
                      <ControlTemplate TargetType="Thumb">
                        <Ellipse Width="13" Height="13" Fill="{StaticResource YouTubeRed}"/>
                      </ControlTemplate>
                    </Thumb.Template>
                  </Thumb>
                </Track.Thumb>
              </Track>
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="VolumeSliderStyle" TargetType="Slider" BasedOn="{StaticResource ProgressSlider}">
      <Setter Property="Width" Value="80"/>
      <Setter Property="Height" Value="14"/>
      <Setter Property="Background" Value="#55FFFFFF"/>
      <Setter Property="Foreground" Value="#FFFFFF"/>
    </Style>

    <Style x:Key="SettingsCombo" TargetType="ComboBox">
      <Setter Property="MinWidth" Value="260"/>
      <Setter Property="Height" Value="32"/>
      <Setter Property="Margin" Value="0,4,0,12"/>
      <Setter Property="Foreground" Value="#101010"/>
      <Setter Property="Background" Value="#FFFFFF"/>
    </Style>
  </Window.Resources>

  <Grid x:Name="RootGrid" Background="Black">
    <!-- Video fills the entire window. Chrome lives in Popups (separate HWNDs) so it
         appears above the VLC native HwndHost. (WPF airspace workaround.) -->
    <vlc:VideoView x:Name="VideoView" Background="Black"/>

    <!-- Top fade: title -->
    <Popup x:Name="TopChromePopup"
           Placement="Absolute"
           AllowsTransparency="True"
           StaysOpen="True"
           HorizontalOffset="0"
           VerticalOffset="0">
      <Border x:Name="TopChrome" Height="64"
              MouseEnter="OnChromeMouseEnter"
              MouseLeave="OnChromeMouseLeave"
              MouseMove="OnChromeMouseMove">
        <Border.Background>
          <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#B0000000" Offset="0"/>
            <GradientStop Color="#00000000" Offset="1"/>
          </LinearGradientBrush>
        </Border.Background>
        <TextBlock x:Name="TitleText" Margin="20,12,20,0" VerticalAlignment="Top"
                   Foreground="{StaticResource ChromeText}" FontSize="14" FontFamily="Segoe UI"
                   TextTrimming="CharacterEllipsis" Opacity="0.92"/>
      </Border>
    </Popup>

    <!-- Bottom overlay chrome -->
    <Popup x:Name="BottomChromePopup"
           Placement="Absolute"
           AllowsTransparency="True"
           StaysOpen="True"
           HorizontalOffset="0"
           VerticalOffset="0">
      <Border x:Name="BottomChrome" Padding="16,28,16,12"
              MouseEnter="OnChromeMouseEnter"
              MouseLeave="OnChromeMouseLeave"
              MouseMove="OnChromeMouseMove">
        <Border.Background>
          <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#00000000" Offset="0"/>
            <GradientStop Color="#CC000000" Offset="1"/>
          </LinearGradientBrush>
        </Border.Background>
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="18"/>
            <RowDefinition Height="44"/>
          </Grid.RowDefinitions>

          <Slider Grid.Row="0" x:Name="ScrubBar" Style="{StaticResource ProgressSlider}"
                  Minimum="0" Maximum="1" Value="0"
                  PreviewMouseLeftButtonDown="OnScrubMouseDown"
                  PreviewMouseLeftButtonUp="OnScrubMouseUp"/>

          <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" x:Name="PlayPauseButton" Style="{StaticResource PlayerButton}"
                      ToolTip="Play/Pause (Space)" Click="OnPlayPauseClick"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0,8,0">
                          <Button x:Name="MuteButton" Style="{StaticResource PlayerButton}"
                      ToolTip="Mute (M)" Click="OnMuteClick"/>
              <Slider x:Name="VolumeSlider" Style="{StaticResource VolumeSliderStyle}"
                      Minimum="0" Maximum="100" Value="100" ValueChanged="OnVolumeChanged"
                      VerticalAlignment="Center" Margin="6,0,4,0"/>
            </StackPanel>

            <TextBlock Grid.Column="2" VerticalAlignment="Center" Foreground="{StaticResource ChromeText}"
                       FontSize="13" FontFamily="Segoe UI" Margin="6,0,0,0">
              <Run x:Name="CurrentTimeRun" Text="0:00"/><Run Text=" / "/><Run x:Name="DurationRun" Text="0:00"/>
            </TextBlock>

            <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center">
                          <Button x:Name="SettingsButton" Style="{StaticResource PlayerButton}"
                      ToolTip="Settings" Click="OnSettingsClick"/>
                          <Button x:Name="FullscreenButton" Style="{StaticResource PlayerButton}"
                      ToolTip="Fullscreen (F)" Click="OnFullscreenClick"/>
            </StackPanel>
          </Grid>
        </Grid>
      </Border>
    </Popup>

    <Popup x:Name="SettingsPopup" PlacementTarget="{Binding ElementName=SettingsButton}" Placement="Top" StaysOpen="False" AllowsTransparency="True">
      <Border Background="#202020" CornerRadius="6" Padding="16" BorderBrush="#555555" BorderThickness="1">
        <StackPanel Width="300">
          <TextBlock Text="Audio" Foreground="White" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
          <ComboBox x:Name="AudioTrackCombo" Style="{StaticResource SettingsCombo}" SelectionChanged="OnAudioTrackChanged" DisplayMemberPath="Name"/>
          <TextBlock Text="Subtitles" Foreground="White" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
          <ComboBox x:Name="SubtitleCombo" Style="{StaticResource SettingsCombo}" SelectionChanged="OnSubtitleChanged" DisplayMemberPath="Name"/>
        </StackPanel>
      </Border>
    </Popup>
  </Grid>
</Window>
